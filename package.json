{
  "name": "@lab-anssi/ui-kit",
  "version": "1.55.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/betagouv/lab-anssi-ui-kit.git"
  },
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/betagouv/lab-anssi-ui-kit/issues"
  },
  "homepage": "https://github.com/betagouv/lab-anssi-ui-kit#readme",
  "packageManager": "pnpm@11.17.0",
  "scripts": {
    "build": "vite build && npm run build:manifest && npm run prepack",
    "build:tokens": "node src/tokens/build.config.ts && pnpm prettier -w .storybook/lab-anssi-themes.css",
    "build:webcomponents": "vite -c vite.webcomponents.config.ts build",
    "build:styles:dsfr": "sass src/lib/styles/dsfr-variables.scss dist/assets/dsfr-variables.css -I node_modules -I node_modules/@gouvfr/dsfr --no-source-map",
    "build:manifest": "node scripts/generate-ui-manifest.mjs",
    "prepare": "husky",
    "prepack": "npm run build:webcomponents && npm run copy:icons && publint",
    "test": "vitest run",
    "storybook:dev": "STORYBOOK_ENV=development storybook dev -p 6006",
    "storybook:build": "STORYBOOK_ENV=production storybook build",
    "storybook:build-dev": "STORYBOOK_ENV=development storybook build",
    "storybook:test": "STORYBOOK_ENV=production npm run test-storybook",
    "test-storybook": "vitest --project=storybook",
    "copy:icons": "cp -r node_modules/@gouvfr/dsfr/dist/icons/* src/lib/assets/icones/dsfr && cp -r src/lib/assets/ dist/",
    "preinstall": "npx only-allow@1.2.2 pnpm"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "type": "module",
  "exports": {
    "./dist/webcomponents": {
      "types": "./dist/webcomponents/lab-anssi-ui-kit.jsx.d.ts",
      "import": "./dist/webcomponents/lab-anssi-ui-kit.iife.js"
    },
    "./web-types.json": "./dist/web-types.json"
  },
  "web-types": "./dist/web-types.json",
  "peerDependencies": {
    "svelte": "~5.55.10 || ~5.56.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "~5.2.1",
    "@eslint/compat": "~2.1.0",
    "@eslint/js": "~10.0.1",
    "@fullhuman/postcss-purgecss": "~8.0.0",
    "@gouvfr/dsfr": "1.14.4",
    "@storybook/addon-a11y": "~10.5.0",
    "@storybook/addon-docs": "~10.5.0",
    "@storybook/addon-svelte-csf": "~5.1.2",
    "@storybook/addon-themes": "~10.5.0",
    "@storybook/addon-vitest": "~10.5.0",
    "@storybook/svelte-vite": "~10.5.0",
    "@sveltejs/vite-plugin-svelte": "~6.2.4",
    "@testing-library/jest-dom": "~6.9.1",
    "@testing-library/svelte": "~5.4.2",
    "@types/node": "~24.13.3",
    "@vitest/browser": "~4.1.10",
    "@vitest/browser-playwright": "~4.1.10",
    "@vitest/coverage-v8": "~4.1.10",
    "concurrently": "~10.0.3",
    "cssnano": "~8.0.2",
    "dotenv": "~17.4.2",
    "eslint": "~10.7.0",
    "eslint-config-prettier": "~10.1.8",
    "eslint-plugin-storybook": "~10.4.6",
    "eslint-plugin-svelte": "~3.18.0",
    "globals": "~17.7.0",
    "http-server": "~14.1.1",
    "husky": "~9.1.7",
    "lint-staged": "~17.0.8",
    "playwright": "~1.61.1",
    "postcss": "~8.5.19",
    "postcss-discard-empty": "~8.0.1",
    "postcss-root-to-host": "~0.0.0",
    "prettier": "~3.8.5",
    "prettier-plugin-svelte": "~3.5.2",
    "publint": "~0.3.21",
    "sass": "~1.101.0",
    "storybook": "~10.5.0",
    "style-dictionary": "^5.5.0",
    "svelte": "~5.56.5",
    "svelte-check": "~4.7.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "~8.62.1",
    "vite": "~7.3.6",
    "vitest": "~4.1.10",
    "wait-on": "~9.0.10"
  },
  "lint-staged": {
    "*.js": "eslint --cache --fix",
    "*.{js,ts,css,md,yml}": "prettier --write"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  },
  "pnpm": {
    "overrides": {
      "rollup": ">=4.30.0",
      "flatted": ">=3.4.2",
      "lodash": ">=4.18.0",
      "minimatch": ">=10.2.3",
      "picomatch": ">=4.0.4",
      "axios": ">=1.15.2",
      "follow-redirects": ">=1.16.0"
    }
  }
}
